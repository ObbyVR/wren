{
  "manifest_version": 3,
  "name": "Wren Nexus Bridge",
  "version": "0.1.0",
  "description": "Connects Wren IDE to native browser windows for live preview and network inspection. Only controls windows opened by Wren.",
  "homepage_url": "https://wren.dev",

  "browser_specific_settings": {
    "gecko": {
      "id": "nexus-bridge@wren.dev",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "nativeMessaging",
    "scripting",
    "windows",
    "tabs",
    "webRequest"
  ],

  "host_permissions": [],

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "content_scripts": [],

  "action": {
    "default_title": "Wren Nexus Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
